{
  "name": "@pulse-ide/frontend",
  "version": "0.1.0",
  "private": true,
  "description": "PulseCode AI IDE frontend (Electron + React)",
  "main": "dist/electron/main.js",
  "scripts": {
    "dev": "vite",
    "build": "tsc -p tsconfig.json && vite build",
    "electron": "electron .",
    "electron:dev": "concurrently \"vite\" \"wait-on http://localhost:5173 && electron .\"",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@pulse-ide/shared": "workspace:*",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "zustand": "^4.5.0",
    "monaco-editor": "^0.49.0",
    "@monaco-editor/react": "^4.6.0"
  },
  "devDependencies": {
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.0",
    "electron": "^31.0.0",
    "typescript": "^5.4.0",
    "vite": "^5.3.0",
    "concurrently": "^8.2.0",
    "wait-on": "^7.2.0"
  }
}
