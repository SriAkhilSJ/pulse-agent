{
  "name": "pulse-ide",
  "version": "0.1.0",
  "description": "PulseCode AI IDE — monorepo",
  "private": true,
  "scripts": {
    "dev": "pnpm --parallel -r dev",
    "build": "pnpm -r build",
    "build:shared": "pnpm --filter @pulse-ide/shared build",
    "build:backend": "pnpm --filter @pulse-ide/backend build",
    "build:frontend": "pnpm --filter @pulse-ide/frontend build",
    "dev:backend": "pnpm --filter @pulse-ide/backend dev",
    "dev:frontend": "pnpm --filter @pulse-ide/frontend dev",
    "lint": "pnpm -r lint",
    "clean": "pnpm -r exec rm -rf dist node_modules"
  },
  "engines": {
    "node": ">=18.0.0",
    "pnpm": ">=8.0.0"
  },
  "devDependencies": {
    "typescript": "^5.4.0"
  },
  "dependencies": {
    "puppeteer": "^25.1.0"
  }
}
